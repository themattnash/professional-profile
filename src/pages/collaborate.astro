---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Let's Collaborate | Matt Nash"
  description="Get in touch about AI evaluation, constraint architecture, red teaming, welfare research collaboration, or speaking."
>
  <header class="mb-12">
    <h1 class="text-3xl font-serif text-stone-900 mb-4">Let's Collaborate</h1>
  </header>

  <section>
    <p class="text-stone-600 text-sm leading-relaxed mb-8">
      For research collaboration, welfare research conversations, speaking, or informal
      questions about evaluation and constraint design. LinkedIn is the best place to start.
      Calendly is there if you'd prefer to book time directly.
    </p>

    <div class="space-y-4 mb-10">
      <a
        href="https://linkedin.com/in/themattnash"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-between no-underline group border border-stone-200 rounded px-5 py-4 bg-white hover:border-indigo-400 transition-colors"
      >
        <div>
          <p class="text-stone-900 font-medium text-sm group-hover:text-indigo-700 transition-colors">LinkedIn</p>
          <p class="text-stone-600 text-xs mt-0.5 font-mono">linkedin.com/in/themattnash</p>
        </div>
        <span class="text-stone-600 group-hover:text-indigo-600 transition-colors text-sm" aria-hidden="true">&rarr;</span>
      </a>

      <a
        href="https://github.com/themattnash"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-between no-underline group border border-stone-200 rounded px-5 py-4 bg-white hover:border-indigo-400 transition-colors"
      >
        <div>
          <p class="text-stone-900 font-medium text-sm group-hover:text-indigo-700 transition-colors">GitHub</p>
          <p class="text-stone-600 text-xs mt-0.5 font-mono">github.com/themattnash</p>
        </div>
        <span class="text-stone-600 group-hover:text-indigo-600 transition-colors text-sm" aria-hidden="true">&rarr;</span>
      </a>

    </div>

    <div class="border-t border-stone-200 pt-8">
      <h3 class="text-xs font-mono uppercase tracking-widest text-stone-600 mb-5">Available for</h3>
      <ul class="space-y-2 text-sm text-stone-700" role="list">
        <li class="flex items-start gap-2">
          <span class="text-indigo-600 mt-0.5" aria-hidden="true">&#8250;</span>
          <span>AI evaluation design and adversarial red teaming</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-indigo-600 mt-0.5" aria-hidden="true">&#8250;</span>
          <span>Constraint architecture consulting for AI product teams</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-indigo-600 mt-0.5" aria-hidden="true">&#8250;</span>
          <span>Fractional product leadership for AI-native companies</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-indigo-600 mt-0.5" aria-hidden="true">&#8250;</span>
          <span>AI welfare research collaboration</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-indigo-600 mt-0.5" aria-hidden="true">&#8250;</span>
          <span>Speaking on evaluation methodology, failure modes, and constraint design</span>
        </li>
      </ul>
    </div>
  </section>
</Layout>
